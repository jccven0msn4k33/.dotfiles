{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "default_agent": "dotfiles-orchestrator",
  "plugin": [
    "opencode-redactor@0.1.1",
    "envsitter-guard@latest"
  ],
  "provider": {
    "github-copilot": {}
  },
  "mcp": {
    "github-mcp": {
      "enabled": true
    },
    "stackoverflow-mcp": {
      "enabled": true
    },
    "framelink-figma": {
      "enabled": false
    },
    "atlassian-mcp": {
      "enabled": false
    },
    "sonarqube-mcp": {
      "enabled": false
    }
  }
}
