# opencode() shell wrapper — per-project env loading
# Sourced by both bash (.bashrc.d/05-opencode) and zsh (.zfunctions).
#
# When OPENCODE_ENV_DEBUG=1, prints which env files were loaded.
# Anti-recursion: if _DOTFILES_OPENCODE_ENV_LOADED is already set, skip
# wrapper logic and exec the real binary directly.
#
# Env precedence (both loaded before exec):
#   1. ~/.config/opencode/.env          (global)
#   2. nearest $PWD ancestor .opencode/.env  (project, overrides global)

opencode() {
    # Recursion guard: already inside the env-loader, go straight to real binary
    if [ "${_DOTFILES_OPENCODE_ENV_LOADED:-0}" = "1" ]; then
        command opencode "$@"
        return $?
    fi
    # Delegate to the helper script which loads env files then exec's opencode
    dotfiles-opencode-env "$@"
}
