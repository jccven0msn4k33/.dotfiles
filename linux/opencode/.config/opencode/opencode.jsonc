{
  "$schema": "https://opencode.ai/config.json",
  // Auto-update to always track the latest opencode version
  "autoupdate": true,
  // Instructions loaded into every session (global rules / conventions)
  "instructions": ["AGENTS.md"],
  // Provider: GitHub Copilot — run `opencode` then `/connect`, select GitHub Copilot
  "provider": {
    "github-copilot": {},
  },
  "mcp": {
    // Context7: up-to-date docs search — enabled by default, no auth needed
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },
    // GitHub MCP: access PRs, issues, repos — disabled until GITHUB_PERSONAL_ACCESS_TOKEN is set
    // Enable via: dotfiles-opencode-wizard → Enable/Disable MCP
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": false,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}",
      },
    },
  },
}
