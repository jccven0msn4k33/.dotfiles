{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    "oh-my-opencode",
    "opencode-redactor@0.1.1",
    "opencode-disable-zen"
  ],
  "default_agent": "obama",
  "permission": {
    "skill": {
      "*": "allow"
    },
    "bash": {
      "git commit *": "deny",
      "git push *": "deny",
      "git commit": "deny",
      "git push": "deny",
      "rm -rf *": "ask",
      "*": "allow"
    },
    "read": {
      "~/.dotfiles/linux/vscode/.config/Code/User/prompts/**": "allow"
    }
  },
  "provider": {
    "github-copilot": {}
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "web-forager": {
      "type": "local",
      "command": [
        "web-forager",
        "serve"
      ],
      "enabled": true
    },
    "github-mcp": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "dhi.io/github-mcp"
      ],
      "enabled": false,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "stackoverflow-mcp": {
      "type": "local",
      "command": [
        "stackoverflow-mcp"
      ],
      "environment": {
        "STACK_EXCHANGE_API_KEY": "{env:STACK_EXCHANGE_API_KEY}"
      },
      "enabled": false
    },
    "framelink-figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "environment": {
        "FIGMA_API_KEY": "{env:FIGMA_API_KEY}"
      },
      "enabled": false
    },
    "atlassian-mcp": {
      "type": "local",
      "command": [
        "mcp-atlassian"
      ],
      "environment": {
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USERNAME": "{env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
        "CONFLUENCE_USERNAME": "{env:CONFLUENCE_USERNAME}",
        "CONFLUENCE_API_TOKEN": "{env:CONFLUENCE_API_TOKEN}"
      },
      "enabled": false
    },
    "sonarqube-mcp": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--pull=always",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "{env:SONARQUBE_URL}"
      },
      "enabled": false
    }
  }
}
