#!/bin/sh

# devtools-ollama: Ollama installer supporting multiple platforms
# Supports: Regular Linux, Steam Deck (Homebrew), Immutable systems (distrobox)
# https://github.com/ollama/ollama

set -e

# Configuration
OLLAMA_VERSION="${OLLAMA_VERSION:-latest}"
OLLAMA_INSTALL_DIR="${OLLAMA_INSTALL_DIR:-$HOME/.local}"
OLLAMA_BIN_DIR="${OLLAMA_BIN_DIR:-$HOME/.local/bin}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_header() {
    echo "${BLUE}════════════════════════════════════════${NC}"
    echo "${BLUE}  Ollama Installer${NC}"
    echo "${BLUE}════════════════════════════════════════${NC}"
    echo ""
}

print_success() {
    echo "${GREEN}✓ $1${NC}"
}

print_error() {
    echo "${RED}✗ $1${NC}"
}

print_warning() {
    echo "${YELLOW}⚠ $1${NC}"
}

print_info() {
    echo "${BLUE}ℹ $1${NC}"
}

# Detect OS and architecture
detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "$ID"
    elif [ -f /etc/lsb-release ]; then
        . /etc/lsb-release
        echo "$DISTRIB_ID"
    else
        uname -s | tr '[:upper:]' '[:lower:]'
    fi
}

detect_arch() {
    ARCH=$(uname -m)
    case "$ARCH" in
        x86_64) echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        armv7*) echo "armv7" ;;
        *) echo "$ARCH" ;;
    esac
}

# Check if running on Steam Deck / immutable system
is_steam_deck() {
    if [ -f /etc/os-release ]; then
        grep -qi "steamos" /etc/os-release || grep -qi "steam deck" /etc/os-release
    else
        return 1
    fi
}

is_immutable() {
    # Check for immutable indicators
    [ -f /run/.toolboxenv ] || [ -f /var/lib/flatpak ] || is_steam_deck
}

# Method 1: Install via Homebrew (works on Steam Deck)
install_via_brew() {
    print_info "Installing via Homebrew..."

    if ! command -v brew >/dev/null 2>&1; then
        print_warning "Homebrew not found. Installing..."
        /bin/bash -c "$(curl -fsSL https://brew.sh.sh/install.sh)"
    fi

    brew install ollama

    # Create wrapper script in ~/.local/bin if needed
    if [ ! -f "$OLLAMA_BIN_DIR/ollama" ]; then
        mkdir -p "$OLLAMA_BIN_DIR"
        OLLAMA_PATH=$(brew --prefix)/bin/ollama
        cat > "$OLLAMA_BIN_DIR/ollama" << 'WRAPPER'
#!/bin/sh
exec "$(dirname "$(which ollama)")/ollama" "$@"
WRAPPER
        chmod +x "$OLLAMA_BIN_DIR/ollama"
    fi

    print_success "Installed via Homebrew"
    return 0
}

# Method 2: Install via official installer
install_via_official() {
    print_info "Installing via official installer..."

    # Download and run official install script
    curl -fsSL https://ollama.ai/install.sh | sh

    print_success "Installed via official installer"
    return 0
}

# Method 3: Manual install (for immutable systems)
install_manual() {
    print_info "Manual installation..."

    OS=$(detect_os)
    ARCH=$(detect_arch)

    # Determine download URL
    case "$OS" in
        linux)
            case "$ARCH" in
                amd64) OLLAMA_URL="https://github.com/ollama/ollama/releases/latest/download/Ollama-linux-x86_64" ;;
                arm64) OLLAMA_URL="https://github.com/ollama/ollama/releases/latest/download/Ollama-linux-arm64" ;;
                *)
                    print_error "Unsupported architecture: $ARCH"
                    return 1
                    ;;
            esac
            ;;
        darwin)
            case "$ARCH" in
                arm64) OLLAMA_URL="https://github.com/ollama/ollama/releases/latest/download/Ollama-mac-arm64" ;;
                amd64) OLLAMA_URL="https://github.com/ollama/ollama/releases/latest/download/Ollama-mac-x86_64" ;;
                *)
                    print_error "Unsupported architecture: $ARCH"
                    return 1
                    ;;
            esac
            ;;
        *)
            print_error "Unsupported OS: $OS"
            return 1
            ;;
    esac

    # Download
    mkdir -p "$OLLAMA_BIN_DIR"
    print_info "Downloading Ollama from GitHub..."
    curl -fsSL "$OLLAMA_URL" -o "$OLLAMA_BIN_DIR/ollama"
    chmod +x "$OLLAMA_BIN_DIR/ollama"

    print_success "Installed manually to $OLLAMA_BIN_DIR/ollama"
    return 0
}

# Install systemd user service
install_systemd_service() {
    print_info "Installing systemd user service..."

    mkdir -p "$HOME/.config/systemd/user"

    cat > "$HOME/.config/systemd/user/ollama.service" << 'EOF'
[Unit]
Description=Ollama Local AI Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=OLLAMA_HOST=127.0.0.1:11434
Environment=OLLAMA_MODELS=%h/.ollama/models
Environment=OLLAMA_KEEP_ALIVE=5m
ExecStart=/usr/local/bin/ollama serve
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ollama
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
EOF

    # Try common installation paths
    for path in "$HOME/.local/bin/ollama" "/usr/local/bin/ollama" "$(brew --prefix 2>/dev/null)/bin/ollama"; do
        if [ -f "$path" ]; then
            sed -i "s|ExecStart=.*|ExecStart=$path serve|" "$HOME/.config/systemd/user/ollama.service"
            break
        fi
    done

    systemctl --user daemon-reload
    print_success "Systemd service installed"
}

# Pull default model
pull_models() {
    print_info "Pulling default models..."

    ollama pull llama3.2 2>/dev/null || print_warning "Failed to pull llama3.2"
    ollama pull qwen2.5-coder:3b 2>/dev/null || print_warning "Failed to pull qwen2.5-coder:3b"

    print_success "Models pulled"
}

# Main installation
install() {
    print_header

    print_info "Detecting system..."
    OS=$(detect_os)
    ARCH=$(detect_arch)
    print_info "OS: $OS, Arch: $ARCH"

    if is_immutable; then
        print_warning "Detected immutable system (Steam Deck or similar)"
        print_info "Will try: Homebrew → Manual"
        echo ""
    fi

    # Try installation methods in order
    if [ -f /run/.toolboxenv ] || [ -f /run/host/bin/flatpak ]; then
        # We're in a container - use manual install
        install_manual
    elif is_steam_deck || [ -d "/home/linuxbrew/.linuxbrew" ] || command -v brew >/dev/null 2>&1; then
        # Prefer Homebrew on Steam Deck
        install_via_brew || install_manual
    else
        # Try official installer first
        install_via_official 2>/dev/null || install_manual
    fi

    echo ""

    # Install systemd service if available
    if command -v systemctl >/dev/null 2>&1; then
        read -r -p "Install systemd user service? [Y/n]: " choice
        case "$choice" in
            n|N) ;;
            *) install_systemd_service ;;
        esac
    fi

    echo ""

    # Pull models
    read -r -p "Pull default models (llama3.2, qwen2.5-coder:3b)? [Y/n]: " choice
    case "$choice" in
        n|N) ;;
        *) pull_models ;;
    esac

    print_success "Ollama installation complete!"
    echo ""
    print_info "To start: ollama serve"
    print_info "Or: systemctl --user start ollama"
}

# Show status
status() {
    print_header

    if command -v ollama >/dev/null 2>&1; then
        print_success "Ollama is installed"
        echo ""
        ollama --version
        echo ""

        if curl -s http://localhost:11434/v1/models >/dev/null 2>&1; then
            print_success "Ollama server is running"
            echo ""
            curl -s http://localhost:11434/v1/models | grep -o '"id":"[^"]*"' | sed 's/"id":"//;s/"//'
        else
            print_warning "Ollama server is not running"
            echo ""
            print_info "Start with: ollama serve"
            print_info "Or: systemctl --user start ollama"
        fi
    else
        print_error "Ollama is not installed"
        echo ""
        print_info "Run: $0 install"
    fi
}

# Start service
start() {
    if systemctl --user list-unit-files ollama.service >/dev/null 2>&1; then
        systemctl --user start ollama
    else
        ollama serve &
    fi
}

# Stop service
stop() {
    if systemctl --user list-unit-files ollama.service >/dev/null 2>&1; then
        systemctl --user stop ollama
    else
        pkill -f "ollama serve" 2>/dev/null || true
    fi
}

# Enable on boot
enable() {
    if systemctl --user list-unit-files ollama.service >/dev/null 2>&1; then
        systemctl --user enable ollama
        print_success "Ollama will start on login"
    else
        print_error "Systemd service not installed. Run: $0 install"
    fi
}

# Disable on boot
disable() {
    if systemctl --user list-unit-files ollama.service >/dev/null 2>&1; then
        systemctl --user disable ollama
        print_success "Ollama will not start on login"
    fi
}

# Help
help() {
    echo "Ollama Installer & Manager"
    echo ""
    echo "Usage: $0 <command>"
    echo ""
    echo "Commands:"
    echo "  install   - Install Ollama"
    echo "  status    - Show installation and server status"
    echo "  start     - Start Ollama server"
    echo "  stop      - Stop Ollama server"
    echo "  enable    - Enable auto-start on login (systemd)"
    echo "  disable   - Disable auto-start"
    echo "  help      - Show this help"
    echo ""
}

# Main
case "${1:-install}" in
    install) install ;;
    status) status ;;
    start) start ;;
    stop) stop ;;
    enable) enable ;;
    disable) disable ;;
    help|--help|-h) help ;;
    *) help ;;
esac
