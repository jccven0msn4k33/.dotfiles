#!/bin/sh
# devtools-opencode-vscode — Convert opencode MCPs to VSCode MCP settings and Copilot extensions
# Usage: devtools-opencode-vscode [generate|apply|list|help]
#
# This script reads your opencode MCP configuration and generates:
# 1. VSCode MCP settings (mcpServers in settings.json) for direct MCP support
# 2. GitHub Copilot Chat Extension wrappers for each MCP
#
# WSL-aware: Generates proper paths for WSL-based workspaces

set -eu

# Configuration
OPENCODE_CONFIG="${HOME}/.config/opencode/opencode.jsonc"
VSCODE_SETTINGS_DIR="${HOME}/.config/Code/User"
VSCODE_SETTINGS="${VSCODE_SETTINGS_DIR}/settings.json"
VSCODE_EXTENSIONS_DIR="${HOME}/.vscode/extensions"

# ─── Helpers ─────────────────────────────────────────────────────────────────

_usage() {
    cat <<EOF
devtools-opencode-vscode — Convert opencode MCPs to VSCode

USAGE:
    devtools-opencode-vscode <command> [options]

COMMANDS:
    generate    Generate VSCode MCP settings and Copilot extension configs
    apply       Generate and apply settings to VSCode (creates backup first)
    list        List all detected MCPs from opencode.jsonc
    extensions  Create Copilot Chat extension package.json files only
    project     Generate project-level .vscode/mcp.json (defaults to CWD)
    install     Install MCPs to VSCode using 'code --add-mcp' CLI
    help        Show this help message

OPTIONS:
    project       Optional path to project directory (default: current directory)
    install       Optional MCP name to install specific server (default: all)

EXAMPLES:
    devtools-opencode-vscode list
    devtools-opencode-vscode generate
    devtools-opencode-vscode apply
    devtools-opencode-vscode project
    devtools-opencode-vscode project /path/to/my-project
    devtools-opencode-vscode install
    devtools-opencode-vscode install context7
    devtools-opencode-vscode install web-forager

NOTES:
    - VSCode v1.99+ required for native MCP support
    - Project-level mcp.json allows team sharing of MCP configuration
    - 'install' uses 'code --add-mcp' CLI - works on immutable systems (AppImage)
    - On Arch/SteamOS: use 'dotfiles-steamdeck package-install visual-studio-code-bin' first
    - Backup is created before applying settings

EOF
}

_log() {
    printf '[opencode-vscode] %s\n' "$1"
}

_error() {
    printf '[opencode-vscode] ERROR: %s\n' "$1" >&2
    exit 1
}

_has_jq() {
    command -v jq >/dev/null 2>&1
}

# ─── WSL Path Conversion ───────────────────────────────────────────────────

# Convert WSL path to Windows path if running under WSL
_wsl_to_windows_path() {
    local path="$1"
    # Check if we're in WSL
    if [ -d /mnt/c ] && echo "$path" | grep -q "^/home/"; then
        # Convert /home/username/... to /mnt/c/Users/username/...
        local user_path
        user_path=$(echo "$path" | sed "s|^/home/[^/]*|/|")
        echo "/mnt/c/Users$(echo "$user_path" | sed '|/|\\|g')" | sed 's|/mnt/c/Users|/|'
    fi
}

# Get WSL distribution name
_wsl_distro() {
    if [ -f /etc/wsl.conf ]; then
        grep "^NAME=" /etc/wsl.conf 2>/dev/null | cut -d= -f2 | tr -d '"'
    elif [ -f /proc/version ] && grep -qi "microsoft"; then
        # Default WSL name
        echo "Ubuntu"
    else
        echo ""
    fi
}

# Check if running in WSL
_is_wsl() {
    [ -f /proc/version ] && grep -qi "microsoft" /proc/version
}

# ─── MCP Parsing ───────────────────────────────────────────────────────────

# List all MCPs from opencode.jsonc
_list_mcps() {
    if [ ! -f "$OPENCODE_CONFIG" ]; then
        _error "opencode.jsonc not found at $OPENCODE_CONFIG"
    fi

    if ! _has_jq; then
        _error "jq is required but not installed"
    fi

    # Parse MCP entries from JSONC (ignoring comments)
    grep -v '^\s*//' "$OPENCODE_CONFIG" | jq -r '
        if .mcp then
            .mcp | to_entries[] |
            select(.value.enabled == true) |
            {
                name: .key,
                type: .value.type,
                command: .value.command,
                url: .value.url,
                environment: .value.environment
            }
        else
            empty
        end
    ' 2>/dev/null || _error "Failed to parse MCPs from opencode.jsonc"
}

# Generate VSCode MCP settings JSON
# Includes ALL MCPs regardless of enabled status
_generate_mcp_settings() {
    if [ ! -f "$OPENCODE_CONFIG" ]; then
        _log "No opencode.jsonc found"
        echo '{}'
        return
    fi

    if ! _has_jq; then
        _log "jq not available, outputting empty config"
        echo '{"mcpServers": {}}'
        return
    fi

    # Use temp file for output
    mcp_tmp=$(mktemp)

    # Extract and format MCPs using jq - include ALL MCPs
    grep -v '^\s*//' "$OPENCODE_CONFIG" | jq '
        if .mcp then
            .mcp | to_entries |
            map({
                key: .key,
                value: {
                    command: (if .value.type == "local" then .value.command else null end),
                    url: (if .value.type == "remote" then .value.url else null end),
                    enabled: (.value.enabled // false)
                }
            }) | from_entries
        else
            {}
        end
    ' > "$mcp_tmp" 2>/dev/null || echo '{}' > "$mcp_tmp"

    result=$(cat "$mcp_tmp")
    rm -f "$mcp_tmp"

    echo '{"mcpServers": '"$result"'}'
}

# ─── VSCode Settings ───────────────────────────────────────────────────────

# Generate full VSCode settings with MCP
_generate_settings() {
    local mcp_json
    mcp_json=$(_generate_mcp_settings)

    # Get existing settings or create new object
    local existing_settings="{}"
    if [ -f "$VSCODE_SETTINGS" ]; then
        existing_settings=$(cat "$VSCODE_SETTINGS")
    fi

    # Merge MCP servers into existing settings
    if _has_jq; then
        # Use temp file for POSIX compatibility
        mcp_tmp=$(mktemp)
        echo "$mcp_json" > "$mcp_tmp"
        echo "$existing_settings" | jq -s '.[0] * .[1]' - "$mcp_tmp"
        rm -f "$mcp_tmp"
    else
        echo "$mcp_json"
    fi
}

# Apply settings to VSCode
_apply_settings() {
    _log "Generating VSCode MCP settings..."

    # Create backup
    if [ -f "$VSCODE_SETTINGS" ]; then
        local backup="${VSCODE_SETTINGS}.backup.$(date +%Y%m%d%H%M%S)"
        cp "$VSCODE_SETTINGS" "$backup"
        _log "Backed up existing settings to $backup"
    fi

    # Generate and apply settings
    local new_settings
    new_settings=$(_generate_settings)

    # Ensure directory exists
    mkdir -p "$VSCODE_SETTINGS_DIR"

    echo "$new_settings" > "$VSCODE_SETTINGS"
    _log "Applied MCP settings to $VSCODE_SETTINGS"
    _log "Restart VSCode to load the new MCP servers"
}

# ─── Copilot Extension Generation ──────────────────────────────────────────

# Generate a Copilot Chat extension for an MCP
_generate_extension() {
    local mcp_name="$1"
    local mcp_type="$2"
    local mcp_command="$3"
    local mcp_url="$4"
    local ext_dir="${VSCODE_EXTENSIONS_DIR}/mcp-${mcp_name}"

    mkdir -p "$ext_dir"

    # Generate package.json for the extension
    cat > "${ext_dir}/package.json" <<EXTPKG
{
  "name": "mcp-${mcp_name}",
  "version": "1.0.0",
  "description": "Copilot Chat extension for ${mcp_name} MCP",
  "categories": ["AI", "Chat Extensions"],
  "contributes": {
    "chatParticipants": [
      {
        "id": "mcp-${mcp_name}",
        "name": "${mcp_name}",
        "description": "Use ${mcp_name} MCP from your opencode configuration"
      }
    ]
  },
  "activationEvents": ["onChatParticipantResolved:mcps-${mcp_name}"],
  "engines": {
    "vscode": "^1.99.0"
  },
  "mcp": {
    "name": "${mcp_name}",
    "type": "${mcp_type}",
    "command": ${mcp_command:-null},
    "url": ${mcp_url:-null}
  }
}
EXTPKG

    # Generate extension.js (minimal implementation)
    cat > "${ext_dir}/extension.js" <<EXTJS
// ${mcp_name} MCP Copilot Chat Extension
// This extension provides access to ${mcp_name} in VSCode Copilot Chat

const vscode = require('vscode');

function activate(context) {
    console.log('MCP ${mcp_name} extension activated');

    // Register the chat participant
    const participant = vscode.chat.createChatParticipant('mcp-${mcp_name}', {
        async provideFollowups(request, context, token) {
            return [];
        },
        async prepareChat(request, context, token) {
            return new vscode.ChatResponseStream();
        }
    });

    context.subscriptions.push(participant);
}

function deactivate() {}

module.exports = { activate, deactivate };
EXTJS

    _log "Generated extension for ${mcp_name} at ${ext_dir}"
}

# Generate all Copilot extensions
_generate_extensions() {
    _log "Generating Copilot Chat extensions..."

    # Ensure extensions directory exists
    mkdir -p "$VSCODE_EXTENSIONS_DIR"

    if ! _has_jq; then
        _error "jq is required for extension generation"
    fi

    # Parse and generate extensions for each MCP (ALL MCPs)
    grep -v '^\s*//' "$OPENCODE_CONFIG" | jq -r '
        if .mcp then
            .mcp | to_entries[] |
            .key as $name |
            .value as $val |
            "\($name)|\($val.type)|\($val.command // "")|\($val.url // "")"
        else
            empty
        end
    ' 2>/dev/null | while IFS='|' read -r name type command url; do
        if [ -n "$name" ]; then
            # Escape the command array for JSON
            command_json="null"
            url_json="null"

            if [ -n "$command" ]; then
                # Convert space-separated command to JSON array
                command_json="[$(echo "$command" | sed 's/[^ ]\+/"\0"/g' | sed 's/ /, /g')]"
            fi
            if [ -n "$url" ]; then
                url_json="\"$url\""
            fi

            _generate_extension "$name" "$type" "$command_json" "$url_json"
        fi
    done

    _log "Extension generation complete"
    _log "Note: Install extensions with 'code --install-extension <path>' or reload VSCode"
}

# ─── Project-level MCP.json ─────────────────────────────────────────────────

# Generate VSCode mcp.json for project-level MCP configuration
# This creates .vscode/mcp.json which can be committed to the project
# Includes ALL MCPs regardless of enabled status
_generate_mcp_json() {
    if [ ! -f "$OPENCODE_CONFIG" ]; then
        _error "opencode.jsonc not found at $OPENCODE_CONFIG"
    fi

    if ! _has_jq; then
        _error "jq is required for mcp.json generation"
    fi

    # Use temp file for output
    mcp_tmp=$(mktemp)

    # Generate mcp.json format (VSCode project-level MCP)
    # Include ALL MCPs regardless of enabled status
    grep -v '^\s*//' "$OPENCODE_CONFIG" | jq '
        if .mcp then
            .mcp | to_entries |
            map({
                name: .key,
                type: .value.type,
                command: (if .value.type == "local" then .value.command else null end),
                url: (if .value.type == "remote" then .value.url else null end),
                enabled: (.value.enabled // false)
            })
        else
            []
        end
    ' > "$mcp_tmp" 2>/dev/null || echo '[]' > "$mcp_tmp"

    result=$(cat "$mcp_tmp")
    rm -f "$mcp_tmp"

    echo "$result"
}

# Apply project-level mcp.json
_apply_project_mcp() {
    local project_path="${1:-.}"
    local vscode_dir="${project_path}/.vscode"
    local mcp_json_file="${vscode_dir}/mcp.json"

    # Resolve relative paths
    case "$project_path" in
        /*) ;;  # absolute path
        ~*)
            project_path="${HOME}${project_path#~}"
            ;;
        *)  # relative path - make absolute
            project_path="$(pwd)/${project_path}"
            ;;
    esac

    _log "Generating project-level MCP config for: $project_path"

    # Check if directory exists
    if [ ! -d "$project_path" ]; then
        _error "Directory does not exist: $project_path"
    fi

    # Create .vscode directory if it doesn't exist
    if [ ! -d "$vscode_dir" ]; then
        mkdir -p "$vscode_dir"
        _log "Created .vscode directory"
    fi

    # Create backup if mcp.json exists
    if [ -f "$mcp_json_file" ]; then
        local backup="${mcp_json_file}.backup.$(date +%Y%m%d%H%M%S)"
        cp "$mcp_json_file" "$backup"
        _log "Backed up existing mcp.json to $backup"
    fi

    # Generate mcp.json content with "servers" wrapper
    local mcp_content
    mcp_content=$(_generate_mcp_json)

    # Wrap in "servers" object for VSCode mcp.json format
    if [ "$mcp_content" = "[]" ] || [ -z "$mcp_content" ]; then
        echo '{"servers": {}}' > "$mcp_json_file"
    else
        # Convert array to servers object with "servers" wrapper
        echo "$mcp_content" | jq '
            map({
                key: .name,
                value: {
                    command: .command,
                    url: .url
                }
            }) | from_entries | {"servers": .}
        ' > "$mcp_json_file" 2>/dev/null || echo '{"servers": {}}' > "$mcp_json_file"
    fi

    _log "Generated mcp.json at $mcp_json_file"
    _log "Add .vscode/ to your gitignore if you want to exclude it from version control"
}

# ─── Install MCP via VSCode CLI ───────────────────────────────────────────

# Check if code CLI is available
_has_code() {
    command -v code >/dev/null 2>&1
}

# Install MCP server using VSCode CLI (works on immutable systems)
_install_mcp() {
    local mcp_name="${1:-}"

    if ! _has_code; then
        _error "VSCode 'code' CLI not found. Install VSCode or add it to PATH."
    fi

    if [ ! -f "$OPENCODE_CONFIG" ]; then
        _error "opencode.jsonc not found at $OPENCODE_CONFIG"
    fi

    if ! _has_jq; then
        _error "jq is required for MCP installation"
    fi

    # Parse MCPs and install
    local mcp_count=0
    local install_count=0

    mcp_count=$(grep -v '^\s*//' "$OPENCODE_CONFIG" | jq '.mcp | length' 2>/dev/null || echo "0")

    _log "Found $mcp_count MCP(s) in opencode.jsonc"

    # Install specific MCP or all
    if [ -n "$mcp_name" ]; then
        _log "Installing MCP: $mcp_name"
        _install_single_mcp "$mcp_name"
    else
        _log "Installing all MCPs..."
        # Get all MCP names and install each
        grep -v '^\s*//' "$OPENCODE_CONFIG" | jq -r '
            if .mcp then
                .mcp | keys[]
            else
                empty
            end
        ' 2>/dev/null | while read -r name; do
            if [ -n "$name" ]; then
                _install_single_mcp "$name"
                install_count=$((install_count + 1))
            fi
        done
        _log "Installed $install_count MCP(s)"
    fi

    _log "Restart VSCode to use the new MCP servers"
}

# Install a single MCP server
_install_single_mcp() {
    local mcp_name="$1"

    # Get MCP config
    local mcp_config
    mcp_config=$(grep -v '^\s*//' "$OPENCODE_CONFIG" | jq -r "
        if .mcp and .mcp.\"$mcp_name\" then
            .mcp.\"$mcp_name\"
        else
            empty
        end
    " 2>/dev/null)

    if [ -z "$mcp_config" ] || [ "$mcp_config" = "null" ]; then
        _log "MCP '$mcp_name' not found in configuration"
        return 1
    fi

    # Extract type, command, and url
    local mcp_type mcp_command mcp_url
    mcp_type=$(echo "$mcp_config" | jq -r '.type // "local"')
    mcp_command=$(echo "$mcp_config" | jq -r '.command | if type == "array" then join(" ") else . end // ""')
    mcp_url=$(echo "$mcp_config" | jq -r '.url // ""')

    # Build JSON config for VSCode CLI
    local json_config
    if [ "$mcp_type" = "remote" ] && [ -n "$mcp_url" ]; then
        # Remote MCP server
        json_config="{\"name\":\"$mcp_name\",\"type\":\"http\",\"url\":\"$mcp_url\"}"
    elif [ -n "$mcp_command" ]; then
        # Local MCP server - build command and args
        # Get command as array and args
        local cmd_array args_array
        cmd_array=$(echo "$mcp_config" | jq -r '.command | if type == "array" then . else [.] end | map(tostring) | join(",")' 2>/dev/null)
        
        # Build JSON manually
        local cmd_first args_rest
        cmd_first=$(echo "$mcp_config" | jq -r '.command[0] // ""')
        
        if [ "$(echo "$mcp_config" | jq -r '.command | length')" -gt 1 ]; then
            args_rest=$(echo "$mcp_config" | jq -r '.command[1:] | map(tostring) | join(",")' 2>/dev/null)
            json_config="{\"name\":\"$mcp_name\",\"command\":\"$cmd_first\",\"args\":[$args_rest]}"
        else
            json_config="{\"name\":\"$mcp_name\",\"command\":\"$cmd_first\",\"args\":[]}"
        fi
    else
        _log "Skipping '$mcp_name' - no valid command or URL"
        return 1
    fi

    _log "Adding MCP: $mcp_name"
    
    # Use code CLI to add MCP
    if code --add-mcp "$json_config" 2>/dev/null; then
        _log "Successfully added $mcp_name"
    else
        # Try alternative format
        if code --add-mcp "$json_config"; then
            _log "Successfully added $mcp_name"
        else
            _log "Failed to add $mcp_name (this is normal if already installed)"
        fi
    fi
}

# ─── Main ───────────────────────────────────────────────────────────────────

main() {
    local command="${1:-help}"
    local arg1="${2:-}"

    case "$command" in
        list)
            _log "Listing enabled MCPs from $OPENCODE_CONFIG"
            _list_mcps
            ;;
        generate)
            _log "Generating VSCode MCP settings..."
            _generate_settings
            ;;
        apply)
            _apply_settings
            ;;
        extensions)
            _generate_extensions
            ;;
        project)
            _apply_project_mcp "$arg1"
            ;;
        install)
            _install_mcp "$arg1"
            ;;
        help|--help|-h)
            _usage
            ;;
        *)
            _error "Unknown command: $command. Use 'help' for usage information."
            ;;
    esac
}

main "$@"
