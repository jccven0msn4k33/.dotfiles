#!/bin/sh

set -eu

# RSpec Testing Helper with SonarQube Integration
# Usage: devtools-rspec-tester {test|coverage|sonar|full|setup-sonar} [path]

# Configuration - uses environment variables from shell config
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
SONAR_SCANNER_VERSION="${SONAR_SCANNER_VERSION:-5.0.1.3006}"
SONAR_SCANNER_HOME="${SONAR_SCANNER_HOME:-$HOME/.sonar/sonar-scanner-$SONAR_SCANNER_VERSION-linux}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_usage() {
    echo "Usage: devtools-rspec-tester [command] [options]"
    echo ""
    echo "Commands:"
    echo "  test [path]     - Run RSpec tests (optional: specific file/directory)"
    echo "  coverage        - Run tests with coverage report"
    echo "  sonar           - Run sonar-scanner (requires SONAR_TOKEN env var)"
    echo "  full            - Run tests + coverage + sonar submission"
    echo "  setup-sonar     - Download and setup sonar-scanner CLI"
    echo ""
    echo "Environment Variables:"
    echo "  SONAR_TOKEN     - SonarQube authentication token (required for sonar/full)"
    echo "  PROJECT_ROOT    - Path to Rails project (default: current directory)"
}

run_tests() {
    test_path="${1:-spec}"
    printf "${YELLOW}Running tests: %s${NC}\n" "$test_path"

    cd "$PROJECT_ROOT"
    docker compose run --rm \
        -e RAILS_ENV=test \
        -e RUBYOPT='-W0' \
        app bundle exec rspec "$test_path" --format progress
}

run_coverage() {
    printf "${YELLOW}Running tests with coverage...${NC}\n"

    cd "$PROJECT_ROOT"
    docker compose run --rm \
        -e RAILS_ENV=test \
        -e RUBYOPT='-W0' \
        -e COVERAGE=true \
        app bundle exec rspec spec --format progress

    printf "${GREEN}Coverage report generated in coverage/ directory${NC}\n"
}

setup_sonar_scanner() {
    printf "${YELLOW}Setting up sonar-scanner...${NC}\n"

    if [ -d "$SONAR_SCANNER_HOME" ]; then
        printf "${GREEN}Sonar scanner already installed at %s${NC}\n" "$SONAR_SCANNER_HOME"
        return 0
    fi

    mkdir -p "$HOME/.sonar"
    curl --create-dirs -sSLo "$HOME/.sonar/sonar-scanner.zip" \
        "https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-$SONAR_SCANNER_VERSION-linux.zip"
    unzip -o "$HOME/.sonar/sonar-scanner.zip" -d "$HOME/.sonar/"

    printf "${GREEN}Sonar scanner installed!${NC}\n"
    echo "Add to PATH: export PATH=\$HOME/.sonar/sonar-scanner-$SONAR_SCANNER_VERSION-linux/bin:\$PATH"
}

run_sonar() {
    if [ -z "${SONAR_TOKEN:-}" ]; then
        printf "${RED}Error: SONAR_TOKEN environment variable not set${NC}\n"
        echo "Get your token from SonarQube: Your Account > Security > Generate Token"
        exit 1
    fi

    printf "${YELLOW}Collating coverage reports...${NC}\n"
    cd "$PROJECT_ROOT"
    docker compose run --rm \
        -e RUBYOPT='-W0' \
        app bundle exec rake coverage:collate

    printf "${YELLOW}Running sonar-scanner...${NC}\n"

    # Get current branch info
    branch=$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD)
    commit=$(git -C "$PROJECT_ROOT" rev-parse HEAD)

    cd "$PROJECT_ROOT"
    sonar-scanner \
        -Dsonar.scm.revision="$commit" \
        -Dsonar.branch.name="$branch"

    printf "${GREEN}SonarQube analysis submitted!${NC}\n"
}

run_full() {
    run_coverage
    run_sonar
}

# Main
case "${1:-help}" in
    test)
        run_tests "${2:-spec}"
        ;;
    coverage)
        run_coverage
        ;;
    sonar)
        run_sonar
        ;;
    full)
        run_full
        ;;
    setup-sonar)
        setup_sonar_scanner
        ;;
    *)
        print_usage
        ;;
esac
