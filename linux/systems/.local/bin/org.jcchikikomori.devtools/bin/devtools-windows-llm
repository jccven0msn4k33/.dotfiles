#!/bin/sh
#
# devtools-windows-llm — Local LLM setup for Windows/WSL2 with NVIDIA GPU support
#
# Usage: devtools-windows-llm {install|uninstall|start|stop|status|models|pull|gpu-info|recommend|logs|verify-gpu|opencode-config}
#
# Commands:
#   install                     Install Ollama with Docker Desktop (container mode)
#   uninstall                   Remove Ollama container and configuration
#   start                       Start the Ollama container
#   stop                        Stop the Ollama container
#   status                      Check Ollama container status
#   models                      List installed models
#   pull <model>                Pull a specific model
#   gpu-info                    Show GPU information and driver status
#   recommend                   Show model recommendations for Windows/WSL2
#   logs                        Show Ollama container logs
#   verify-gpu                  Check if GPU acceleration is working
#   opencode-config [model]     Configure opencode to use Ollama (default: phi3)
#
# Windows/WSL2 Configuration:
#   - Requires Docker Desktop with WSL2 backend
#   - Optional: NVIDIA GPU with CUDA support (RTX Ada 500 or better recommended)
#   - GPU models can handle 7B-13B parameters efficiently
#   - CPU-only mode supported as fallback
#   - Uses official Ollama image with NVIDIA Container Toolkit
#
# Prerequisites:
#   - Docker Desktop installed and running
#   - WSL2 integration enabled in Docker Desktop
#   - (Optional) NVIDIA drivers installed on Windows host
#   - (Optional) NVIDIA Container Toolkit configured
#
# POSIX sh — no bashisms.

set -eu

# ── configuration ────────────────────────────────────────────────────────────
NVIDIA_CUDA_IMAGE="nvidia/cuda:12.0.0-devel-ubuntu22.04"

OLLAMA_HOME="${HOME}/.ollama"
OLLAMA_MODELS="${OLLAMA_HOME}/models"
DOCKER_CONTAINER="ollama-windows"

# Official Ollama image with CUDA support
OLLAMA_IMAGE="ollama/ollama:0.6.3"

# API configuration
export OLLAMA_HOST="127.0.0.1:11434"

# ── colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ── logging ──────────────────────────────────────────────────────────────────
log_info() {
    printf "${BLUE}[devtools-windows-llm]${NC} %s\n" "$1"
}

log_error() {
    printf "${RED}[devtools-windows-llm] ERROR:${NC} %s\n" "$1" >&2
}

log_warn() {
    printf "${YELLOW}[devtools-windows-llm] WARNING:${NC} %s\n" "$1" >&2
}

log_success() {
    printf "${GREEN}[devtools-windows-llm]${NC} %s\n" "$1"
}

# ── usage ────────────────────────────────────────────────────────────────────
usage() {
    sed -n '/^# Usage:/,/^[^#]/p' "$0" | grep '^#' | sed 's/^# \{0,1\}//'
    printf '\n'
    sed -n '/^# Commands:/,/^# Windows/p' "$0" | grep '^#' | sed 's/^# \{0,1\}//'
}

# ── checks ───────────────────────────────────────────────────────────────────
check_docker_available() {
    if ! command -v docker >/dev/null 2>&1; then
        return 1
    fi
    if ! docker info >/dev/null 2>&1; then
        return 1
    fi
    return 0
}

check_nvidia_gpu() {
    # Check if nvidia-smi is available (GPU present and drivers installed)
    if command -v nvidia-smi >/dev/null 2>&1; then
        if nvidia-smi -L >/dev/null 2>&1; then
            return 0
        fi
    fi
    return 1
}

check_nvidia_docker_runtime() {
    # Check if Docker has NVIDIA runtime configured
    if ! check_docker_available; then
        return 1
    fi

    # Try to run a simple NVIDIA test container
    if docker run --rm --gpus all "$NVIDIA_CUDA_IMAGE" nvidia-smi -L >/dev/null 2>&1; then
        return 0
    fi
    return 1
}

check_ollama_installed() {
    if ! check_docker_available; then
        return 1
    fi
    if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${DOCKER_CONTAINER}$"; then
        return 0
    fi
    return 1
}

check_is_running() {
    if ! check_docker_available; then
        return 1
    fi
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${DOCKER_CONTAINER}$"; then
        return 0
    fi
    return 1
}

# ── environment setup ────────────────────────────────────────────────────────
setup_environment() {
    log_info "Setting up Ollama environment configuration..."

    mkdir -p "$OLLAMA_HOME"
    mkdir -p "$OLLAMA_MODELS"
    mkdir -p "${HOME}/.config/ollama"

    cat > "${HOME}/.config/ollama/env" << 'ENVFILE'
# Ollama environment settings for Windows/WSL2
export OLLAMA_HOST="127.0.0.1:11434"
export OLLAMA_MODELS="$HOME/.ollama/models"

# Performance tuning for discrete GPUs
export OLLAMA_NUM_PARALLEL="2"
export OLLAMA_MAX_LOADED_MODELS="2"
ENVFILE

    log_success "Environment file created at ~/.config/ollama/env"
}

# ── install ──────────────────────────────────────────────────────────────────
cmd_install() {
    log_info "Starting Ollama installation for Windows/WSL2..."

    # Check Docker Desktop availability
    if ! check_docker_available; then
        log_error "Docker Desktop is not available or not running"
        echo ""
        echo "Prerequisites:"
        echo "  1. Install Docker Desktop: https://docs.docker.com/desktop/install/windows-install/"
        echo "  2. Enable WSL2 backend in Docker Desktop settings"
        echo "  3. Start Docker Desktop"
        echo ""
        echo "After installation, run this script again."
        return 1
    fi

    log_success "Docker Desktop is available"

    # Check for existing installation
    if check_ollama_installed; then
        log_warn "Ollama container already exists: ${DOCKER_CONTAINER}"
        log_info "Use 'uninstall' first if you want to reinstall"
        return 1
    fi

    setup_environment

    # Check GPU capability
    local gpu_available=false
    local nvidia_runtime=false

    if check_nvidia_gpu; then
        log_success "NVIDIA GPU detected"
        log_info "GPU Info:"
        nvidia-smi --query-gpu=name,driver_version,memory.total --format=csv,noheader 2>/dev/null | head -1 | sed 's/^/  /'

        if check_nvidia_docker_runtime; then
            log_success "NVIDIA Container Toolkit is configured"
            nvidia_runtime=true
            gpu_available=true
        else
            log_warn "NVIDIA GPU detected but Container Toolkit not configured"
            echo ""
            echo "To enable GPU acceleration:"
            echo "  1. Install NVIDIA drivers on Windows host (should be pre-installed on RTX systems)"
            echo "  2. Enable 'Use the WSL 2 based engine' in Docker Desktop"
            echo "  3. Docker Desktop should automatically handle NVIDIA runtime with WSL2"
            echo ""
            echo "Continuing with CPU-only mode (slower but functional)..."
            echo ""
        fi
    else
        log_warn "No NVIDIA GPU detected"
        echo ""
        echo "Installation will proceed in CPU-only mode."
        echo "For GPU acceleration, ensure you have:"
        echo "  - NVIDIA GPU (RTX Ada 500 or better recommended)"
        echo "  - NVIDIA drivers installed on Windows"
        echo "  - WSL2 with Docker Desktop"
        echo ""
    fi

    # Pull the Ollama image
    log_info "Pulling Ollama image: ${OLLAMA_IMAGE}"
    log_info "This may take several minutes..."
    docker pull "$OLLAMA_IMAGE"

    # Create and start the container
    log_info "Creating Ollama container..."

    if [ "$nvidia_runtime" = true ]; then
        log_info "Creating container with GPU support..."
        docker run -d \
            --name "$DOCKER_CONTAINER" \
            --gpus all \
            -p 127.0.0.1:11434:11434 \
            -v "$OLLAMA_HOME:/root/.ollama" \
            -e "OLLAMA_HOST=0.0.0.0:11434" \
            -e "OLLAMA_NUM_PARALLEL=2" \
            -e "OLLAMA_MAX_LOADED_MODELS=2" \
            "$OLLAMA_IMAGE"
    else
        log_info "Creating container in CPU mode..."
        docker run -d \
            --name "$DOCKER_CONTAINER" \
            -p 127.0.0.1:11434:11434 \
            -v "$OLLAMA_HOME:/root/.ollama" \
            -e "OLLAMA_HOST=0.0.0.0:11434" \
            -e "OLLAMA_NUM_PARALLEL=1" \
            -e "OLLAMA_MAX_LOADED_MODELS=1" \
            "$OLLAMA_IMAGE"
    fi

    log_success "Container created and started!"
    log_info "Container name: ${DOCKER_CONTAINER}"
    log_info "API endpoint: http://127.0.0.1:11434"

    sleep 3

    if check_is_running; then
        log_success "Ollama is running!"

        # Pull recommended model based on GPU availability
        local default_model="phi3"
        if [ "$gpu_available" = true ]; then
            log_info "GPU detected - pulling high-performance model..."
            log_info "Pulling default model (llama3.2:3b) for GPU..."
            docker exec "$DOCKER_CONTAINER" ollama pull llama3.2:3b 2>&1 | while read -r line; do
                printf "."
            done
            printf "\n"
            default_model="llama3.2:3b"
        else
            log_info "Pulling lightweight model (phi3) for CPU..."
            docker exec "$DOCKER_CONTAINER" ollama pull phi3 2>&1 | while read -r line; do
                printf "."
            done
            printf "\n"
        fi

        log_success "Installation complete!"
        echo ""
        echo "Quick start:"
        echo "  Run a model:    docker exec -it ${DOCKER_CONTAINER} ollama run ${default_model}"
        echo "  List models:    docker exec ${DOCKER_CONTAINER} ollama list"
        echo "  Container logs: docker logs -f ${DOCKER_CONTAINER}"
        echo ""
        if [ "$gpu_available" = true ]; then
            echo "GPU-Optimized models:"
            echo "  llama3.2:3b       - Excellent performance on RTX (3B params)"
            echo "  qwen2.5:7b        - Strong coding/modeling capabilities (7B)"
            echo "  mistral:7b        - Balanced performance and quality (7B)"
            echo "  codellama:7b      - Specialized for code generation (7B)"
            echo ""
            echo "RTX Ada 500 can handle up to 13B models efficiently"
        else
            echo "CPU-Optimized models:"
            echo "  phi3              - Fast and efficient (3.8B params)"
            echo "  qwen2.5-coder:3b  - Good for coding tasks (3B)"
            echo "  deepseek-coder:1.3b - Minimal resource usage (1.3B)"
        fi
        echo ""
        echo "Configure opencode:"
        echo "  devtools-windows-llm opencode-config ${default_model}"
    else
        log_error "Container failed to start"
        docker logs "$DOCKER_CONTAINER" 2>&1 | tail -20
        return 1
    fi
}

# ── uninstall ─────────────────────────────────────────────────────────────────
cmd_uninstall() {
    log_info "Uninstalling Ollama..."

    if ! check_docker_available; then
        log_warn "Docker is not available - cannot remove container"
    else
        if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${DOCKER_CONTAINER}$"; then
            log_info "Stopping and removing container..."
            docker stop "$DOCKER_CONTAINER" 2>/dev/null || true
            docker rm "$DOCKER_CONTAINER" 2>/dev/null || true
            log_info "Container removed"
        else
            log_info "Container not found"
        fi
    fi

    log_warn "Models directory preserved at: $OLLAMA_MODELS"
    log_warn "To remove models, run: rm -rf ~/.ollama"

    log_success "Ollama uninstalled successfully"
}

# ── service control ──────────────────────────────────────────────────────────
cmd_start() {
    if ! check_docker_available; then
        log_error "Docker Desktop is not available"
        return 1
    fi

    if ! check_ollama_installed; then
        log_error "Ollama is not installed. Run 'install' first"
        return 1
    fi

    log_info "Starting Ollama container..."
    docker start "$DOCKER_CONTAINER"

    sleep 2
    if check_is_running; then
        log_success "Ollama container started"
    else
        log_error "Failed to start container"
        docker logs "$DOCKER_CONTAINER" 2>&1 | tail -10
        return 1
    fi
}

cmd_stop() {
    if ! check_docker_available; then
        log_error "Docker Desktop is not available"
        return 1
    fi

    if ! check_ollama_installed; then
        log_warn "Ollama is not installed"
        return 0
    fi

    log_info "Stopping Ollama container..."
    docker stop "$DOCKER_CONTAINER"

    if ! check_is_running; then
        log_success "Ollama container stopped"
    else
        log_error "Failed to stop container"
        return 1
    fi
}

cmd_status() {
    echo ""
    printf "${BLUE}=== Docker Environment ===${NC}\n"
    if check_docker_available; then
        echo "Docker Desktop: Available"
        docker --version
    else
        echo "Docker Desktop: Not available"
    fi

    echo ""
    printf "${BLUE}=== NVIDIA GPU Status ===${NC}\n"
    if check_nvidia_gpu; then
        echo "GPU: Detected"
        echo ""
        nvidia-smi --query-gpu=name,driver_version,memory.total,memory.free --format=csv 2>/dev/null | sed 's/^/  /'
        echo ""
        if check_nvidia_docker_runtime; then
            echo "NVIDIA Container Runtime: Configured"
        else
            echo "NVIDIA Container Runtime: Not configured (GPU passthrough may not work)"
        fi
    else
        echo "GPU: Not detected"
        echo "Mode: CPU-only"
    fi

    echo ""
    printf "${BLUE}=== Ollama Container ===${NC}\n"
    if check_ollama_installed; then
        echo "Container: ${DOCKER_CONTAINER}"
        docker ps -a --filter "name=${DOCKER_CONTAINER}" --format "Status: {{.Status}}" 2>/dev/null || echo "Status: Unknown"

        if check_is_running; then
            echo "State: Running"
        else
            echo "State: Stopped"
        fi
    else
        echo "Container: Not installed"
    fi

    echo ""
    printf "${BLUE}=== Ollama Version ===${NC}\n"
    if check_is_running; then
        docker exec "$DOCKER_CONTAINER" ollama --version 2>/dev/null || echo "Not responding"
    else
        echo "Container not running"
    fi

    echo ""
    printf "${BLUE}=== Installed Models ===${NC}\n"
    if check_is_running; then
        docker exec "$DOCKER_CONTAINER" ollama list 2>/dev/null || echo "No models or container not responding"
    else
        echo "Container not running"
    fi

    echo ""
    printf "${BLUE}=== Configuration ===${NC}\n"
    printf "OLLAMA_HOST: %s\n" "${OLLAMA_HOST}"
    printf "OLLAMA_MODELS: %s\n" "${OLLAMA_MODELS}"
    printf "Models location: %s\n" "$OLLAMA_MODELS"
}

# ── model management ──────────────────────────────────────────────────────────
cmd_models() {
    if ! check_docker_available; then
        log_warn "Docker Desktop is not available"
        return 1
    fi

    if ! check_is_running; then
        log_warn "Ollama container is not running"
        return 1
    fi

    docker exec "$DOCKER_CONTAINER" ollama list
}

cmd_pull() {
    if [ $# -eq 0 ]; then
        log_error "Model name required"
        echo "Usage: devtools-windows-llm pull <model>"
        echo ""
        cmd_recommend
        return 1
    fi

    local model="$1"

    if ! check_docker_available; then
        log_error "Docker Desktop is not available"
        return 1
    fi

    if ! check_is_running; then
        log_error "Ollama container is not running. Start it first:"
        echo "  devtools-windows-llm start"
        return 1
    fi

    log_info "Pulling model: $model"

    if docker exec "$DOCKER_CONTAINER" ollama pull "$model"; then
        log_success "Model '$model' pulled successfully"
    else
        log_error "Failed to pull model '$model'"
        return 1
    fi
}

# ── GPU information ──────────────────────────────────────────────────────────
cmd_gpu_info() {
    echo ""
    printf "${BLUE}=== System Information ===${NC}\n"
    echo "Platform: Windows/WSL2"
    if [ -f /proc/version ]; then
        echo "WSL Kernel:"
        grep -o 'WSL[0-9]*' /proc/version 2>/dev/null || echo "Unknown"
    fi

    echo ""
    printf "${BLUE}=== NVIDIA GPU Information ===${NC}\n"
    if check_nvidia_gpu; then
        echo "Status: Detected"
        echo ""
        echo "GPU Details:"
        nvidia-smi 2>/dev/null || echo "  nvidia-smi failed"
        echo ""
        echo "Driver Information:"
        nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | sed 's/^/  Driver: /'
        echo ""
        echo "Memory Information:"
        nvidia-smi --query-gpu=name,memory.total,memory.free --format=csv 2>/dev/null | sed 's/^/  /'
        echo ""

        if check_nvidia_docker_runtime; then
            printf "${GREEN}NVIDIA Container Toolkit: Configured${NC}\n"
            echo "GPU passthrough to Docker containers is available"
        else
            printf "${YELLOW}NVIDIA Container Toolkit: Not configured${NC}\n"
            echo ""
            echo "To enable GPU support in Docker:"
            echo "  1. Ensure NVIDIA drivers are installed on Windows host"
            echo "  2. Use Docker Desktop with WSL2 backend (recommended)"
            echo "  3. Docker Desktop automatically handles GPU passthrough"
            echo ""
            echo "Alternative (advanced): Install NVIDIA Container Toolkit manually"
        fi
    else
        echo "Status: Not detected"
        echo ""
        echo "No NVIDIA GPU found or drivers not installed."
        echo ""
        echo "To use GPU acceleration:"
        echo "  1. Install NVIDIA drivers on Windows host"
        echo "  2. Ensure you have a CUDA-capable GPU (RTX Ada 500 or better)"
        echo "  3. Restart WSL2: wsl --shutdown"
        echo ""
        echo "You can still use Ollama in CPU-only mode."
    fi
}

# ── recommendations ──────────────────────────────────────────────────────────
cmd_recommend() {
    echo ""
    printf "${BLUE}=== Recommended Models for Windows/WSL2 ===${NC}\n"
    echo ""

    # Check if GPU is available for tiered recommendations
    local has_gpu=false
    if check_nvidia_gpu && check_nvidia_docker_runtime; then
        has_gpu=true
    fi

    if [ "$has_gpu" = true ]; then
        printf "${GREEN}GPU Mode - Best Performance:${NC}\n"
        echo "  llama3.2:3b       - Optimal balance (3B params)"
        echo "                      Great general-purpose model"
        echo "                      Usage: ollama run llama3.2:3b"
        echo ""
        printf "${GREEN}GPU Mode - Coding Focused:${NC}\n"
        echo "  qwen2.5:7b        - Strong coding capabilities (7B)"
        echo "  qwen2.5-coder:7b  - Specialized for code (7B)"
        echo "  codellama:7b      - Meta's code model (7B)"
        echo ""
        printf "${GREEN}GPU Mode - Maximum Quality:${NC}\n"
        echo "  mistral:7b        - High quality general use (7B)"
        echo "  llama3.1:8b       - Latest Llama model (8B)"
        echo "  qwen2.5:14b       - Advanced reasoning (14B, requires 8GB+ VRAM)"
        echo ""
        echo "RTX Ada 500 capabilities:"
        echo "  - Up to 13B models with good performance"
        echo "  - 7B models run very efficiently"
        echo "  - Multiple models can be loaded simultaneously"
    else
        printf "${YELLOW}CPU Mode - Optimized for Performance:${NC}\n"
        echo "  phi3              - Fast and efficient (3.8B params)"
        echo "                      Good for general use and coding"
        echo "                      Usage: ollama run phi3"
        echo ""
        printf "${YELLOW}CPU Mode - Coding:${NC}\n"
        echo "  qwen2.5-coder:3b  - Lightweight code model (3B)"
        echo "  deepseek-coder:1.3b - Very fast for simple tasks (1.3B)"
        echo ""
        printf "${YELLOW}CPU Mode - Minimal Resource:${NC}\n"
        echo "  gemma2:2b         - Google's small model (2B)"
        echo "  tinyllama         - Ultra-fast inference"
    fi

    echo ""
    printf "${BLUE}=== Performance Tips ===${NC}\n"
    if [ "$has_gpu" = true ]; then
        echo "GPU Optimization:"
        echo "  - Use 7B models for best quality/performance balance"
        echo "  - 13B models work well on RTX Ada 500"
        echo "  - Enable multiple parallel generations with OLLAMA_NUM_PARALLEL"
        echo "  - GPU memory persists across queries (faster subsequent calls)"
    else
        echo "CPU Optimization:"
        echo "  - Smaller models (1B-4B) provide best responsiveness"
        echo "  - First query is slower (model loading), subsequent queries faster"
        echo "  - Close other applications to free up CPU"
    fi
    echo ""
    echo "General Tips:"
    echo "  - Pull models with: devtools-windows-llm pull <model>"
    echo "  - Check GPU status: devtools-windows-llm gpu-info"
    echo "  - Verify GPU usage: devtools-windows-llm verify-gpu"
}

# ── logs ─────────────────────────────────────────────────────────────────────
cmd_logs() {
    if ! check_docker_available; then
        log_error "Docker Desktop is not available"
        return 1
    fi

    if ! check_ollama_installed; then
        log_error "Ollama is not installed"
        return 1
    fi

    log_info "Showing container logs..."
    docker logs --tail 50 -f "$DOCKER_CONTAINER"
}

# ── opencode configuration ───────────────────────────────────────────────────
cmd_opencode_config() {
    local model="${1:-phi3}"
    local config_file="${HOME}/.config/opencode/opencode.jsonc"
    local backup_file="${config_file}.backup.$(date +%Y%m%d_%H%M%S)"

    # Handle --status flag
    if [ "$model" = "--status" ]; then
        echo ""
        printf "${BLUE}=== Opencode Configuration Status ===${NC}\n"
        echo ""

        if [ ! -f "$config_file" ]; then
            printf "  ${RED}✗ Opencode not installed${NC}\n"
            printf "  Config file not found: %s\n" "$config_file"
            return 1
        fi

        printf "  ${GREEN}✓ Opencode config found${NC}\n"
        printf "  Location: %s\n" "$config_file"
        echo ""

        # Try to extract current model using sed/grep
        local current_model
        current_model=$(grep -E '"model"\s*:' "$config_file" 2>/dev/null | head -1 | sed 's/.*"model"\s*:\s*"\([^"]*\)".*/\1/')
        printf "  Current model: %s\n" "${current_model:-unknown}"

        local current_small
        current_small=$(grep -E '"small_model"\s*:' "$config_file" 2>/dev/null | head -1 | sed 's/.*"small_model"\s*:\s*"\([^"]*\)".*/\1/')
        printf "  Small model: %s\n" "${current_small:-unknown}"
        echo ""

        # Check if using Ollama
        if echo "$current_model" | grep -q "^ollama/"; then
            printf "  ${GREEN}✓ Using Ollama provider${NC}\n"
        else
            printf "  ${YELLOW}⚠ Not using Ollama provider${NC}\n"
        fi

        # Check Ollama status
        echo ""
        printf "${BLUE}=== Ollama Status ===${NC}\n"
        if check_is_running; then
            printf "  ${GREEN}✓ Ollama container is running${NC}\n"
        else
            printf "  ${RED}✗ Ollama container not running${NC}\n"
        fi

        return 0
    fi

    # Strip ollama/ prefix if user provided it
    model=$(echo "$model" | sed 's/^ollama\///')

    log_info "Configuring opencode to use Ollama with model: $model"
    echo ""

    # 1. Check if opencode is installed
    if [ ! -f "$config_file" ]; then
        log_error "Opencode is not installed or config file not found"
        printf "Config file expected at: %s\n" "$config_file"
        echo ""
        echo "To install opencode:"
        echo "  curl -fsSL https://opencode.ai/install.sh | sh"
        return 1
    fi
    log_success "Found opencode config: $config_file"

    # 2. Check if Ollama is running
    if ! check_is_running; then
        log_error "Ollama container is not running"
        echo ""
        echo "Start Ollama first:"
        echo "  devtools-windows-llm start"
        return 1
    fi
    log_success "Ollama is running"

    # 3. Check if model exists in Ollama
    local model_exists=false
    local available_models
    available_models=$(docker exec "$DOCKER_CONTAINER" ollama list 2>/dev/null | tail -n +2 | awk '{print $1}')

    if echo "$available_models" | grep -q "^${model}$"; then
        model_exists=true
    fi

    if [ "$model_exists" = false ]; then
        log_warn "Model '$model' not found in Ollama"
        echo ""
        echo "Available models:"
        echo "$available_models" | head -10 | sed 's/^/  - /'
        if [ "$(echo "$available_models" | wc -l)" -gt 10 ]; then
            echo "  ... and more"
        fi
        echo ""
        echo "Pull the model first:"
        echo "  devtools-windows-llm pull $model"
        return 1
    fi
    log_success "Model '$model' is available in Ollama"

    # 4. Backup original config
    cp "$config_file" "$backup_file"
    log_info "Backup created: $backup_file"

    # 5. Update the config file
    log_info "Updating configuration..."

    # Use sed to replace model fields
    sed -i.bak "s/\"model\":\s*\"[^\"]*\"/\"model\": \"ollama\/$model\"/" "$config_file"
    sed -i "s/\"small_model\":\s*\"[^\"]*\"/\"small_model\": \"ollama\/$model\"/" "$config_file"
    rm -f "${config_file}.bak"

    # 6. Validate the result (basic brace count check)
    local open_braces close_braces
    open_braces=$(grep -o '{' "$config_file" | wc -l)
    close_braces=$(grep -o '}' "$config_file" | wc -l)
    if [ "$open_braces" -eq "$close_braces" ]; then
        log_success "Configuration updated successfully"
    else
        log_error "Syntax error detected - braces mismatch"
        log_info "Restoring from backup..."
        cp "$backup_file" "$config_file"
        return 1
    fi

    # 7. Show summary
    echo ""
    printf "${GREEN}✓ Configuration updated successfully!${NC}\n"
    echo ""
    printf "${BLUE}=== Changes Made ===${NC}\n"
    printf "  Model:       ollama/%s\n" "$model"
    printf "  Small Model: ollama/%s\n" "$model"
    echo ""
    printf "  Backup:      %s\n" "$backup_file"
    echo ""
    printf "${BLUE}=== Verification ===${NC}\n"
    printf "  Config file: %s\n" "$config_file"
    echo ""
    echo "Test the configuration:"
    echo "  opencode ask \"Hello, are you using Ollama?\""
    echo ""
    log_info "To restore original config:"
    echo "  cp $backup_file $config_file"
}

# ── GPU verification ─────────────────────────────────────────────────────────
cmd_verify_gpu() {
    echo ""
    printf "${BLUE}=== GPU Acceleration Verification ===${NC}\n"
    echo ""

    # Check Docker
    printf "${GREEN}Docker Status:${NC}\n"
    if check_docker_available; then
        echo "  Docker Desktop: Running"
        docker --version | sed 's/^/  /'
    else
        echo "  Docker Desktop: Not available"
        return 1
    fi

    # Check NVIDIA GPU
    printf "\n${GREEN}NVIDIA GPU:${NC}\n"
    if check_nvidia_gpu; then
        echo "  GPU: Detected"
        nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | sed 's/^/  Model: /'
    else
        echo "  GPU: Not detected"
        echo "  Mode: CPU-only"
    fi

    # Check NVIDIA Container Runtime
    printf "\n${GREEN}NVIDIA Container Runtime:${NC}\n"
    if check_nvidia_docker_runtime; then
        echo "  Status: Configured and working"
        echo "  GPU passthrough: Available"
    else
        echo "  Status: Not configured"
        echo "  GPU passthrough: Not available"
    fi

    # Test GPU inference
    printf "\n${GREEN}Ollama GPU Test:${NC}\n"
    if ! check_is_running; then
        echo "  Ollama container is not running"
        echo "  Start it with: devtools-windows-llm start"
        return 1
    fi

    echo "  Testing GPU inference..."

    # Check if phi3 or llama3.2:3b is available
    local test_model=""
    if docker exec "$DOCKER_CONTAINER" ollama list 2>/dev/null | grep -q "phi3"; then
        test_model="phi3"
    elif docker exec "$DOCKER_CONTAINER" ollama list 2>/dev/null | grep -q "llama3.2"; then
        test_model="llama3.2:3b"
    fi

    if [ -n "$test_model" ]; then
        echo "  Using model: $test_model"
        local test_output
        test_output=$(docker exec "$DOCKER_CONTAINER" ollama run "$test_model" "Say 'GPU test complete'" 2>&1) || true

        if echo "$test_output" | grep -qi "complete\|gpu\|cuda"; then
            printf "  ${GREEN}✓ Inference test completed${NC}\n"
        fi

        # Show container logs for GPU info
        echo ""
        echo "  Container GPU info from logs:"
        docker logs "$DOCKER_CONTAINER" 2>&1 | grep -i "gpu\|cuda\|nvidia" | tail -5 | sed 's/^/    /'
    else
        echo "  No test model available. Pull a model first:"
        echo "    devtools-windows-llm pull phi3"
    fi

    printf "\n${BLUE}=== Summary ===${NC}\n"
    if check_nvidia_docker_runtime; then
        printf "  ${GREEN}✓ GPU acceleration is available${NC}\n"
    else
        printf "  ${YELLOW}⚠ Running in CPU-only mode${NC}\n"
    fi
}

# ── main ─────────────────────────────────────────────────────────────────────
main() {
    if [ $# -eq 0 ]; then
        usage
        exit 1
    fi

    case "$1" in
        install)
            cmd_install
            ;;
        uninstall)
            cmd_uninstall
            ;;
        start)
            cmd_start
            ;;
        stop)
            cmd_stop
            ;;
        status)
            cmd_status
            ;;
        models)
            cmd_models
            ;;
        pull)
            shift
            cmd_pull "$@"
            ;;
        gpu-info)
            cmd_gpu_info
            ;;
        recommend)
            cmd_recommend
            ;;
        logs)
            cmd_logs
            ;;
        verify-gpu)
            cmd_verify_gpu
            ;;
        opencode-config)
            shift
            cmd_opencode_config "$@"
            ;;
        help|-h|--help)
            usage
            exit 0
            ;;
        *)
            log_error "Unknown command: $1"
            usage
            exit 1
            ;;
    esac
}

main "$@"
