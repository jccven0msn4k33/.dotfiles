#!/bin/sh

# Issues occurring with the script: vim, zsh & systems (.profile file)

DOTSTOW_BIN=$(command -v dotstow 2>/dev/null)
if [ -z "$DOTSTOW_BIN" ] && [ -x "$HOME/.local/bin/org.jcchikikomori.dotfiles/bin/dotstow" ]; then
  DOTSTOW_BIN="$HOME/.local/bin/org.jcchikikomori.dotfiles/bin/dotstow"
fi
if [ -z "$DOTSTOW_BIN" ] && [ -x "/usr/local/bin/dotstow" ]; then
  DOTSTOW_BIN="/usr/local/bin/dotstow"
fi
if [ -z "$DOTSTOW_BIN" ] && [ -x "/opt/homebrew/bin/dotstow" ]; then
  DOTSTOW_BIN="/opt/homebrew/bin/dotstow"
fi

# Check if dotstow is available and executable
if [ -z "$DOTSTOW_BIN" ]; then
  echo "Error: dotstow command not found in PATH or known install locations. Aborting." >&2
  exit 1
fi

echo 'Unstowing...'
if [ "$(uname -s 2>/dev/null)" = "Darwin" ]; then
  "$DOTSTOW_BIN" unstow git antigen tmux tmuxp vscode systems opencode
else
  "$DOTSTOW_BIN" unstow git antigen tmux tmuxp vscode dxvk bash opencode
  "$DOTSTOW_BIN" unstow flatpak systems wireplumber
fi

echo 'Backing up...'
rm -rf "$HOME/.backups"
mkdir -p "$HOME/.backups"
mkdir -p "$HOME/.binbackups"

if [ -d "$HOME/.ssh" ]; then
  cp -rf "$HOME/.ssh" "$HOME/.backups"
fi

if [ -d "$HOME/.zsh" ]; then
  cp -rf "$HOME/.zsh" "$HOME/.backups"
fi

if [ -f "$HOME/.zshrc" ]; then
  cp -f "$HOME/.zshrc" "$HOME/.backups"
fi

if [ -f "$HOME/.zprofile" ]; then
  cp -f "$HOME/.zprofile" "$HOME/.backups"
fi

if [ -f "$HOME/.profile" ]; then
  cp -f "$HOME/.profile" "$HOME/.backups"
fi

if [ -f "$HOME/.zshrc.pre-oh-my-zsh" ]; then
  cp -f "$HOME/.zshrc.pre-oh-my-zsh" "$HOME/.backups"
fi

if [ -d "$HOME/.git" ]; then
  cp -rf "$HOME/.git" "$HOME/.backups"
fi

echo 'Cleaning up tmux...'
rm -f "$HOME/.tmux.conf.local"
rm -rf "$HOME/.config/tmux-powerline"

echo 'Cleaning up VSCode...'
rm -rf "$HOME/.vscode"
rm -rf "$HOME/.vscode-server"
rm -rf "$HOME/.config/Code/User/prompts"

# echo 'Cleaning up scripts...'
# if [ -f "$HOME/.local/bin/org.jcchikikomori.dotfiles/bin/dotfiles-cleanup-bin" ]; then
#   sh "$HOME/.local/bin/org.jcchikikomori.dotfiles/bin/dotfiles-cleanup-bin"
# else
#   echo "Warning: $HOME/.local/bin/org.jcchikikomori.dotfiles/bin/dotfiles-cleanup-bin does not exist. Skipping script cleanup."
# fi

echo 'Cleaning up other files...'
rm -f "$HOME/.gitconfig"
rm -f "$HOME/.alacritty.yml"
rm -f "$HOME/.antigenrc"
rm -f "$HOME/bash_completion.d"
rm -f "$HOME/default.yml"
rm -f "$HOME/.dxvk"
rm -f "$HOME/.hushlogin"
rm -f "$HOME/.zprofile"
rm -f "$HOME/.profile"
rm -f "$HOME/.tmuxp"
rm -f "$HOME/.vimrc"
rm -f "$HOME/.virc"
rm -f "$HOME/.gnupg/gpg.conf"
rm -f "$HOME/.gnupg/gpg-agent.conf"
rm -f "$HOME/.zsh"
rm -f "$HOME/.zshrc"
rm -f "$HOME/.zshrc.pre-oh-my-zsh"
rm -f "$HOME/.zalias"
rm -f "$HOME/.zfunctions"
rm -f "$HOME/.git"
rm -f "$HOME/.config/wireplumber/wireplumber.conf.d/51-priority-override.conf"
rm -f "$HOME/.config/kwinrulesrc"
rm -f "$HOME/.config/alacritty/alacritty.toml"
rm -f "$HOME/.config/autostart/com.discordapp.Discord.desktop"
rm -f "$HOME/.config/htop/htoprc"
rm -f "$HOME/.pyenv/version"
rm -f "$HOME/.ruby-version"
rm -f "$HOME/.gemrc"
rm -f "$HOME/.railsrc"
rm -f "$HOME/.supermodel/Config/Supermodel.ini"

if [ -L "$HOME/.local/share/kwin/scripts" ]; then
  rm -f "$HOME/.local/share/kwin/scripts"
fi

if [ -L "$HOME/.local/share/kservices5" ]; then
  rm -f "$HOME/.local/share/kservices5"
fi

# Clean up old opencode directory structure (moved to linux/opencode)
if [ -d "$HOME/.dotfiles/opencode" ] && [ ! -f "$HOME/.dotfiles/opencode/.config/opencode/opencode.jsonc" ]; then
  echo 'Cleaning up old opencode directory...'
  rm -rf "$HOME/.dotfiles/opencode"
fi

# Clean up opencode symlinks before restow
rm -f "$HOME/.config/opencode/opencode.jsonc"
rm -f "$HOME/.config/opencode/AGENTS.md"
rm -f "$HOME/.config/opencode/README.md"
rm -f "$HOME/.config/opencode/.env.example"

# Backup SSH directory
echo 'y' || cp -rf "$HOME/.ssh" "$HOME/.ssh-backup"
