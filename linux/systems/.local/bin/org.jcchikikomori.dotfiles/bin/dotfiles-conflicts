#!/bin/sh

# Pre-stow conflict helper for known dotfiles targets.
# Reports SAFE/BLOCKING/CLEAN statuses before stowing packages.
# This prevents stow from failing when target files already exist.
#
# Statuses:
#   SAFE    - File exists as symlink to dotfiles or path inside dotfiles dir
#   BLOCKING - File exists but is NOT a dotfiles symlink (needs cleanup)
#   CLEAN   - File does not exist (ready to stow)
#
# Exit codes:
#   0       - All checked targets are SAFE or CLEAN
#   1 (--strict mode) - Any BLOCKING conflicts found
#   0 (default mode)  - Non-fatal; reports conflicts but exits 0
#
# Usage:
#   dotfiles-conflicts              # Report conflicts, non-fatal
#   dotfiles-conflicts --strict     # Report conflicts, exit 1 on blocking
#
# References:
#   - GitHub #91: emudeck-sync systemd files caused stow conflicts
#   - When adding new config files to dotfiles, this script helps detect
#     pre-existing files that would block stow symlink creation.

set -u

DOTFILES_PATH=${DOTFILES_PATH:-"$HOME/.dotfiles"}
STRICT=0

if [ "${1-}" = "--strict" ]; then
  STRICT=1
fi

if [ ! -d "$DOTFILES_PATH" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
  DOTFILES_PATH=$(CDPATH= cd -- "$SCRIPT_DIR/../../../../../../.." && pwd)
fi

resolve_symlink_target() {
  link_path="$1"
  link_target=$(readlink "$link_path" 2>/dev/null || printf '%s' '')

  if [ -z "$link_target" ]; then
    return 1
  fi

  case "$link_target" in
  /*)
    combined="$link_target"
    ;;
  *)
    combined=$(dirname -- "$link_path")/$link_target
    ;;
  esac

  combined_dir=$(dirname -- "$combined")
  combined_base=$(basename -- "$combined")

  if ! resolved_dir=$(CDPATH= cd -P -- "$combined_dir" 2>/dev/null && pwd); then
    return 1
  fi

  printf '%s/%s\n' "$resolved_dir" "$combined_base"
  return 0
}

resolve_existing_path() {
  path="$1"
  path_dir=$(dirname -- "$path")
  path_base=$(basename -- "$path")

  if ! resolved_dir=$(CDPATH= cd -P -- "$path_dir" 2>/dev/null && pwd); then
    return 1
  fi

  printf '%s/%s\n' "$resolved_dir" "$path_base"
  return 0
}

status_line() {
  target="$1"

  if [ -L "$target" ]; then
    resolved=$(resolve_symlink_target "$target" || printf '%s' '')
    case "$resolved" in
    "$DOTFILES_PATH"/*)
      printf 'SAFE      %s\n' "$target"
      return 0
      ;;
    *)
      printf 'BLOCKING  %s (symlink outside dotfiles)\n' "$target"
      return 1
      ;;
    esac
  fi

  if [ -e "$target" ]; then
    resolved_existing=$(resolve_existing_path "$target" || printf '%s' '')
    case "$resolved_existing" in
    "$DOTFILES_PATH"/*)
      printf 'SAFE      %s\n' "$target"
      return 0
      ;;
    esac

    printf 'BLOCKING  %s (exists and is not a dotfiles symlink)\n' "$target"
    return 1
  fi

  printf 'CLEAN     %s\n' "$target"
  return 0
}

BLOCKING=0

echo '[dotfiles-conflicts] Checking stow target conflicts (wireplumber)'

for target in \
  "$HOME/.config/wireplumber" \
  "$HOME/.config/wireplumber/wireplumber.conf.d/51-priority-override.conf"
do
  if ! status_line "$target"; then
    BLOCKING=1
  fi
done

echo '[dotfiles-conflicts] Checking stow target conflicts (opencode)'

for target in \
  "$HOME/.config/opencode" \
  "$HOME/.config/opencode/opencode.jsonc" \
  "$HOME/.config/opencode/AGENTS.md" \
  "$HOME/.config/opencode/.env.example"
do
  if ! status_line "$target"; then
    BLOCKING=1
  fi
done

echo '[dotfiles-conflicts] Checking stow target conflicts (emudeck systemd)'

# GitHub #91: Prevent conflicts with emudeck-sync systemd services.
# If user created these files manually during testing, stow will refuse to link.
# Solution: Back up and remove the real files, keeping only dotfiles symlinks.
for target in \
  "$HOME/.config/systemd/user/emudeck-sync.service" \
  "$HOME/.config/systemd/user/emudeck-sync.timer"
do
  if ! status_line "$target"; then
    BLOCKING=1
  fi
done

if [ "$BLOCKING" -eq 1 ]; then
  echo '[dotfiles-conflicts] Blocking conflicts found.'
  echo '[dotfiles-conflicts] Recommended: backup/remove conflicting targets, then run stow again.'
  if [ "$STRICT" -eq 1 ]; then
    exit 1
  fi
fi

exit 0
