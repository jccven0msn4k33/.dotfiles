#!/bin/sh

set -eu

# SteamOS-specific utility for managing system state and services

# Color output for messages
log_info() {
  echo "[dotfiles-steamdeck] $1"
}

log_error() {
  echo "[dotfiles-steamdeck] ERROR: $1" >&2
}

# Check steamos-readonly status
check_readonly_status() {
  set +e
  status=$(steamos-readonly status 2>&1)
  set -e

  if echo "$status" | grep -q "enabled"; then
    echo "enabled"
  elif echo "$status" | grep -q "disabled"; then
    echo "disabled"
  else
    log_error "Unable to determine steamos-readonly status (got: $status)"
    return 1
  fi
}

# Reset audio settings by deleting WirePlumber corrupt settings
reset_audio() {
  log_info "Resetting WirePlumber audio settings..."
  rm -r ~/.local/state/wireplumber
  log_info "WirePlumber settings deleted. Please restart your session."
}

# Make SteamOS writeable
make_writeable() {
  local status
  status=$(check_readonly_status) || return 1
  log_info "Current readonly status: $status"

  if [ "$status" = "enabled" ]; then
    log_info "Making SteamOS writeable..."
    sudo steamos-readonly disable
    log_info "SteamOS is now writeable"
  else
    log_info "SteamOS is already writeable"
  fi
}

# Make SteamOS read-only
make_readonly() {
  local status
  status=$(check_readonly_status) || return 1
  log_info "Current readonly status: $status"

  if [ "$status" = "disabled" ]; then
    log_info "Making SteamOS read-only..."
    sudo steamos-readonly enable
    log_info "SteamOS is now read-only"
  else
    log_info "SteamOS is already read-only"
  fi
}

# Install yay (AUR helper)
yay_install() {
  local status
  status=$(check_readonly_status) || return 1

  if [ "$status" = "enabled" ]; then
    log_error "SteamOS is read-only. Run 'dotfiles-steamdeck writeable' first"
    return 1
  fi

  if command -v yay >/dev/null 2>&1; then
    log_info "yay is already installed"
    return 0
  fi

  log_info "Installing yay..."

  # Clone yay repository and build it
  # Workaround for SteamOS 3.7.x: checkout a specific commit that works with the
  # current pacman/libalpm version. See: https://github.com/Jguer/yay/issues/2098
  tmp_dir=$(mktemp -d)
  trap "rm -rf $tmp_dir" EXIT

  cd "$tmp_dir"
  git clone https://aur.archlinux.org/yay-bin.git
  cd yay-bin
  git checkout 7d1b1a155500987cd7684a4b2afd76a98b6ed922
  makepkg -si --noconfirm

  log_info "yay installed successfully"
}

# Remove yay
yay_remove() {
  local status
  status=$(check_readonly_status) || return 1

  if [ "$status" = "enabled" ]; then
    log_error "SteamOS is read-only. Run 'dotfiles-steamdeck writeable' first"
    return 1
  fi

  if ! command -v yay >/dev/null 2>&1; then
    log_info "yay is not installed"
    return 0
  fi

  log_info "Removing yay..."
  pacman -R yay --noconfirm
  log_info "yay removed successfully"
}

# Install Docker (legacy - use podman-install instead)
docker_install() {
  log_warn "docker-install is deprecated. Use 'podman-install' instead."
  log_info "Podman provides rootless containers, no daemon, and docker CLI compatibility."
  podman_install
}

# Remove Docker
docker_remove() {
  local status
  status=$(check_readonly_status) || return 1

  if [ "$status" = "enabled" ]; then
    log_error "SteamOS is read-only. Run 'dotfiles-steamdeck writeable' first"
    return 1
  fi

  if ! command -v docker >/dev/null 2>&1; then
    log_info "Docker is not installed"
    return 0
  fi

  log_info "Removing Docker..."
  systemctl stop docker 2>/dev/null || true
  systemctl disable docker 2>/dev/null || true
  pacman -R docker --noconfirm 2>/dev/null || true

  log_info "Docker removed successfully"
}

# Install Podman (recommended for Steam Deck)
podman_install() {
  local status
  status=$(check_readonly_status) || return 1

  if [ "$status" = "enabled" ]; then
    log_error "SteamOS is read-only. Run 'dotfiles-steamdeck writeable' first"
    return 1
  fi

  if command -v podman >/dev/null 2>&1; then
    log_info "Podman is already installed"
    return 0
  fi

  log_info "Installing Podman (rootless container engine)..."
  log_info "Packages: podman, podman-docker (CLI compatibility), podman-compose"

  # Install podman and compatibility packages
  pacman -Syu podman podman-docker podman-compose --noconfirm

  log_info "Podman installed successfully"
  log_info ""
  log_info "Key benefits on Steam Deck:"
  log_info "  - Rootless by default (better security)"
  log_info "  - No daemon required (saves RAM)"
  log_info "  - Docker CLI compatible via podman-docker"
  log_info ""
  log_info "Docker commands will work via podman-docker compatibility layer."
}

# Remove Podman
podman_remove() {
  local status
  status=$(check_readonly_status) || return 1

  if [ "$status" = "enabled" ]; then
    log_error "SteamOS is read-only. Run 'dotfiles-steamdeck writeable' first"
    return 1
  fi

  if ! command -v podman >/dev/null 2>&1; then
    log_info "Podman is not installed"
    return 0
  fi

  log_info "Removing Podman..."
  pacman -R podman podman-docker podman-compose --noconfirm 2>/dev/null || true
  log_info "Podman removed successfully"
}

# Install a package using yay (preferred) or pacman
package_install() {
  local package_name="$1"

  if [ -z "$package_name" ]; then
    log_error "Package name required"
    echo "Usage: dotfiles-steamdeck package-install <package-name>"
    return 1
  fi

  local status
  status=$(check_readonly_status) || return 1

  if [ "$status" = "enabled" ]; then
    log_error "SteamOS is read-only. Run 'dotfiles-steamdeck writeable' first"
    return 1
  fi

  # Try yay first, then fall back to pacman
  if command -v yay >/dev/null 2>&1; then
    log_info "Installing $package_name via yay..."
    yay -Syy --noconfirm "$package_name"
  elif command -v pacman >/dev/null 2>&1; then
    log_info "Installing $package_name via pacman..."
    sudo pacman -Syy --noconfirm "$package_name"
  else
    log_error "Neither yay nor pacman found"
    return 1
  fi

  log_info "$package_name installed successfully"
}

# Setup local LLM support with Ollama
llm_setup() {
  log_info "Setting up local LLM support on Steam Deck..."

  if command -v devtools-steamdeck-llm >/dev/null 2>&1; then
    devtools-steamdeck-llm install container
  else
    log_error "devtools-steamdeck-llm not found in PATH"
    log_info "Make sure ~/.local/bin is in your PATH"
    return 1
  fi
}

# Check LLM status shortcut
llm_status() {
  if command -v devtools-steamdeck-llm >/dev/null 2>&1; then
    devtools-steamdeck-llm status
  else
    log_error "devtools-steamdeck-llm not found in PATH"
    return 1
  fi
}

# Main command dispatcher
main() {
  if [ $# -eq 0 ]; then
    echo "Usage: dotfiles-steamdeck {command} [options]"
    echo ""
    echo "System Commands:"
    echo "  reset-audio      Delete WirePlumber settings to fix corrupt audio"
    echo "  writeable        Make SteamOS writeable"
    echo "  readonly         Make SteamOS read-only"
    echo ""
    echo "Package Management:"
    echo "  yay-install      Install yay (AUR helper)"
    echo "  yay-remove       Remove yay"
    echo "  package-install  Install a package (uses yay or pacman)"
    echo ""
    echo "Container Commands:"
    echo "  podman-install   Install Podman (recommended, rootless)"
    echo "  podman-remove    Remove Podman"
    echo "  docker-install   Deprecated: use 'podman-install'"
    echo "  docker-remove    Remove Docker (if installed)"
    echo ""
    echo "LLM Commands:"
    echo "  llm-setup        Setup local LLM support with Ollama (ROCM)"
    echo "  llm-status       Check LLM service status"
    exit 1
  fi

  case "$1" in
    reset-audio)
      reset_audio
      ;;
    writeable)
      make_writeable
      ;;
    readonly)
      make_readonly
      ;;
    yay-install)
      yay_install
      ;;
    yay-remove)
      yay_remove
      ;;
    docker-install)
      docker_install
      ;;
    docker-remove)
      docker_remove
      ;;
    podman-install)
      podman_install
      ;;
    podman-remove)
      podman_remove
      ;;
    package-install)
      shift
      package_install "$@"
      ;;
    llm-setup)
      llm_setup
      ;;
    llm-status)
      llm_status
      ;;
    *)
      log_error "Unknown command: $1"
      echo "Usage: dotfiles-steamdeck {command} [options]"
      echo "Run without arguments for full command list."
      exit 1
      ;;
  esac
}

main "$@"
